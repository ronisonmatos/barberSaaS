# Valores publicos (nao sao segredo -- a anon key do Supabase e feita pra ir pro navegador, e o
# proprio wrangler.jsonc ja guarda esses mesmos 3 valores em texto puro). Comitado de proposito
# porque o deploy na Cloudflare (Workers Builds) so expoe "Variaveis e segredos" em tempo de
# execucao do Worker -- o passo `next build` roda antes disso, numa etapa separada, e precisa
# desses valores presentes durante o build para inlinar NEXT_PUBLIC_* no bundle do navegador.
NEXT_PUBLIC_SUPABASE_URL=https://smphmeoljjgakghsnvpb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_CVweKnAmbsBvRWEYmLjcBw_RoiExHpa
NEXT_PUBLIC_APP_URL=https://comptus.com.br
